# ============================================================
# .env.example — Variabili di configurazione
# Sistema Cardano Day · ITIS "G. Cardano", Pavia
#
# ISTRUZIONI:
# 1. Copia questo file in .env
# 2. Compila TUTTE le variabili
# 3. NON caricare .env su Git
# ============================================================

# --- DATABASE ---
DB_HOST=localhost
DB_NAME=cardano_day
DB_USER=cardano_user
DB_PASS=PASSWORD_SICURA_QUI
DB_PORT=3306

# --- JWT (min. 32 caratteri, random) ---
# Genera con: php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=CAMBIA_QUESTA_CHIAVE_CON_UNA_STRINGA_RANDOM_DI_64_CARATTERI
JWT_TTL=86400

# --- EMAIL SMTP ---
MAIL_FROM=noreply@itiscardanopv.edu.it
MAIL_NAME=ITIS G. Cardano — Pavia
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=tuaemail@gmail.com
MAIL_PASS=password_app_gmail

# --- APP ---
APP_URL=https://tuodominio.it
APP_ENV=production
